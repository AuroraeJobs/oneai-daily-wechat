# OneAI Daily WeChat 示例环境变量
#
# 使用方法：
#   cp .env.example .env
#   然后把下面的占位值替换成你的公众号真实配置。
#
# 安全提醒：
# - 不要提交 .env 文件。
# - 不要把 WECHAT_APP_SECRET 写进 README、issue、commit message 或聊天记录。
# - GitHub Actions 生产发布请使用仓库 Secrets / Variables。

# 公众号 AppID，示例格式通常以 wx 开头。
WECHAT_APP_ID=wx_your_app_id_here

# 公众号 AppSecret。仅本地 .env 或 GitHub Actions Secret 中配置。
WECHAT_APP_SECRET=replace_with_your_wechat_app_secret

# 公众号素材库中的封面图片 media_id。
# 这是草稿接口必需字段；建议先在公众号后台上传永久图片素材后填入。
WECHAT_THUMB_MEDIA_ID=replace_with_cover_image_media_id

# 默认作者。文章 Front Matter 中的 author 会覆盖这里。
WECHAT_AUTHOR=OneAI

# 本地调试建议保持 true：只渲染 payload，不调用微信 API。
WECHAT_DRY_RUN=true

# true 表示创建草稿后继续提交发布；false 表示只创建草稿。
WECHAT_PUBLISH_AFTER_DRAFT=false

# 是否开启评论：0 关闭，1 开启。
WECHAT_NEED_OPEN_COMMENT=0

# 是否仅粉丝可评论：0 否，1 是。
WECHAT_ONLY_FANS_CAN_COMMENT=0

# 微信 API 基础地址。通常不需要修改。
WECHAT_API_BASE=https://api.weixin.qq.com
